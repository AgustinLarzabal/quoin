enum Continent {
  AFRICA
  AMERICA
  ASIA
  EUROPE
  OCEANIA
}

model Country {
  id        String  @id @default(cuid())
  continent Continent
  isoCode   String  @unique
  name      String  @unique
  
  coins     Coin[]
  series    Serie[]
}

model Serie {
  id        String  @id @default(cuid())
  name      String

  coins     Coin[]

  countryID   String
  country     Country @relation(fields: [countryID], references: [id])
}


model Coin {
  id          String  @id @default(cuid())
  code        String
  name        String
  
  countryID   String
  country     Country @relation(fields: [countryID], references: [id])

  seriesID    String
  series      Serie @relation(fields: [seriesID], references: [id])
}